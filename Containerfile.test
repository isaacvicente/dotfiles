FROM fedora:latest

# Packages needed to run and validate the dotfiles bootstrap flow.
RUN dnf install -y \
    sudo \
    stow \
    curl \
    wget \
    fontconfig \
  flatpak \
  ShellCheck \
    tar \
  && dnf clean all

RUN useradd -m -s /bin/sh tester \
  && printf 'tester ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/tester \
  && chmod 0440 /etc/sudoers.d/tester

USER tester
WORKDIR /work/dotfiles